// ============================================================================
// JOB MONITORING - Health tracking for cron jobs
// ============================================================================

/// Job execution status for tracking cron job health
enum JobStatus {
  running
  success
  failed
  timeout

  @@map("job_status")
}

/// Tracks execution history of all cron jobs for health monitoring.
/// Enables detection of stale jobs (jobs that haven't run in expected interval)
/// and failure alerting. Critical for "running forever" assurance.
model JobRun {
  id          String    @id @default(cuid())
  jobName     String    @map("job_name") // "send-daily-pulse", "ingest-mta-alerts"
  status      JobStatus @default(running)
  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  durationMs  Int?      @map("duration_ms")

  // Results
  itemsProcessed Int?    @map("items_processed")
  itemsFailed    Int?    @map("items_failed")
  errorMessage   String? @map("error_message")
  metadata       Json    @default("{}") // Flexible storage for job-specific data

  @@index([jobName, startedAt])
  @@index([status])
  @@map("job_runs")
}

/// Configuration for job health monitoring.
/// Defines expected run frequency and alerting thresholds.
model JobConfig {
  jobName           String @id @map("job_name")
  displayName       String @map("display_name")
  expectedFrequency String @map("expected_frequency") // "5m", "1h", "24h"
  alertAfterMissed  Int    @default(2) @map("alert_after_missed") // Alert after N missed runs
  isEnabled         Boolean @default(true) @map("is_enabled")
  lastAlertedAt     DateTime? @map("last_alerted_at") @db.Timestamptz

  @@map("job_configs")
}

/// NYC Parks events - free outdoor events, fitness classes, tours
/// Scraped from NYC Parks calendar
model ParkEvent {
  id          String    @id @default(cuid())
  externalId  String    @unique @map("external_id") // Event ID from parks calendar
  name        String
  description String?
  parkName    String    @map("park_name")
  borough     String?
  address     String?
  latitude    Float?
  longitude   Float?
  date        DateTime  @db.Date
  startTime   String?   @map("start_time") // "10:00"
  endTime     String?   @map("end_time") // "12:00"
  category    String?   // "Fitness", "Nature", "Sports", "Arts", "Tours"
  isFree      Boolean   @default(true) @map("is_free")
  url         String?
  imageUrl    String?   @map("image_url")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  fetchedAt   DateTime  @default(now()) @map("fetched_at") @db.Timestamptz

  @@index([date])
  @@index([borough])
  @@index([category])
  @@map("park_events")
}

// ============================================================================
// EMAIL OUTBOX - Idempotency and Tracking for Email Delivery
// ============================================================================

/// Email types for categorization and deduplication
enum EmailType {
  daily_digest
  daily_pulse
  weekly_digest
  day_ahead
  reminder
  monthly_recap
  welcome
  system

  // Time-slot email system (v2)
  morning_briefing
  midday_pulse
  evening_winddown

  @@map("email_type")
}

/// Email sending status for tracking delivery
enum EmailStatus {
  pending
  sent
  failed
  skipped

  @@map("email_status")
}

/// Transactional outbox for reliable email delivery.
/// Implements exactly-once semantics via unique constraint on (recipient, emailType, targetDate).
/// Prevents duplicate emails when cron jobs overlap or retry.
model EmailOutbox {
  id         String     @id @default(cuid())
  recipient  String     // Email address (normalized to lowercase)
  emailType  EmailType  @map("email_type")
  targetDate DateTime   @map("target_date") @db.Date // The date this email is for (not when it was sent)
  subject    String     // Subject line for reference
  resendId   String?    @map("resend_id") // Resend message ID for tracking
  status     EmailStatus @default(pending)
  errorMessage String?  @map("error_message")
  metadata   Json       @default("{}") // Flexible storage for job-specific data
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  sentAt     DateTime?  @map("sent_at") @db.Timestamptz

  // Unique constraint prevents duplicate emails for same recipient/type/date
  @@unique([recipient, emailType, targetDate], name: "recipient_emailType_targetDate")
  @@index([status, targetDate])
  @@index([emailType, targetDate])
  @@map("email_outbox")
}

// ============================================================================
// JOB LOCK - Distributed Locking to Prevent Concurrent Job Runs
// ============================================================================

/// Distributed lock for cron jobs to prevent duplicate execution.
/// When a job starts, it acquires a lock. If another instance tries to run,
/// it will fail to acquire the lock and exit immediately.
model JobLock {
  jobName   String   @id @map("job_name") // Each job can only have one lock
  lockId    String   @map("lock_id") // Unique identifier for this lock instance
  acquiredAt DateTime @default(now()) @map("acquired_at") @db.Timestamptz
  expiresAt DateTime @map("expires_at") @db.Timestamptz // Lock timeout (prevents stuck locks)

  @@index([expiresAt])
  @@map("job_locks")
}

// ============================================================================
// B2B API — Clients, Keys, Logs, Compiled Briefings
// ============================================================================

/// Plan tier for API access rate limiting and billing.
enum ApiPlanTier {
  free       // 100 requests/day
  pro        // 10,000 requests/day
  enterprise // Unlimited

  @@map("api_plan_tier")
}

/// B2B API customer. Separate from B2C User model.
model ApiClient {
  id          String   @id @default(cuid())
  email       String   @unique
  companyName String?  @map("company_name")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  apiKeys ApiKey[]

  @@map("api_clients")
}

/// API key for B2B authentication.
/// Raw key shown once on creation; only SHA-256 hash stored.
model ApiKey {
  id          String      @id @default(cuid())
  hashedKey   String      @unique @map("hashed_key")
  keyPrefix   String      @map("key_prefix") // "sk_live_Ab..." for display
  apiClientId String      @map("api_client_id")
  name        String?     // User-friendly label like "Production Key"
  planTier    ApiPlanTier @default(free) @map("plan_tier")
  isActive    Boolean     @default(true) @map("is_active")
  lastUsedAt  DateTime?   @map("last_used_at") @db.Timestamptz
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  apiClient ApiClient @relation(fields: [apiClientId], references: [id], onDelete: Cascade)
  logs      ApiLog[]

  @@map("api_keys")
}

/// Request log for rate limiting and billing analytics.
model ApiLog {
  id             String   @id @default(cuid())
  apiKeyId       String   @map("api_key_id")
  endpoint       String   // "/api/v1/briefing"
  statusCode     Int      @map("status_code")
  responseTimeMs Int?     @map("response_time_ms")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@index([createdAt])
  @@map("api_logs")
}

/// Pre-compiled API response payload.
/// Refreshed every 15 minutes by the compiler task.
model CompiledBriefing {
  id        String   @id @default(cuid())
  city      String   // "nyc"
  payload   Json     // Full JSONB briefing object
  version   String   @default("1.0") // Schema version
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([city, createdAt])
  @@map("compiled_briefings")
}
